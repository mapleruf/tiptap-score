{
  "name": "@mapleruf/tiptap-score",
  "version": "0.1.1",
  "description": "Tiptap - Music Score Extension powered by VexFlow",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "files": [
    "dist",
    "style.css",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./style.css": "./style.css"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "prepare": "npm run clean && npm run build",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@tiptap/core": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "react": ">=18",
    "react-dom": ">=18",
    "vexflow": "^5.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.2"
  }
}
